theme = Horizon

font-family = "FiraCode Nerd Font Mono"
font-size = 12.0

window-height = 35
window-width = 120
window-padding-x = 12
window-padding-y = 12

quit-after-last-window-closed = true
mouse-shift-capture = never

macos-auto-secure-input = true
macos-option-as-alt = true
macos-titlebar-style = hidden
macos-icon = glass

keybind = global:cmd+ctrl+t=toggle_quick_terminal
# Ghostty reserves Ctrl+Shift for link detection, so it never reaches tmux.
# Forward Ctrl+Shift+n as a CSI-u sequence (matches tmux's extended-keys-format).
keybind = ctrl+shift+n=csi:110;6u

