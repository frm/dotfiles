#!/bin/bash
#
# Determines the tmux window name based on context:
# - If session name matches the window's directory, show the git branch (or directory if not a repo)
# - Otherwise, show the window's directory name
# - Prepends PR status if the current branch has a PR:
#   "(#123) " for open, "(✓ #123) " for merged, "(✗ #123) " for closed, "(⧖ #123) " for queued
# Note: Manually set window names are preserved by tmux's automatic-rename behavior

pane_path="$1"
window_dir="${pane_path##*/}"
session_name=$(tmux display-message -p '#S')

# Look up PR number for the current branch, with file-based caching (5 min TTL)
pr_prefix=""
branch=$(git -C "$pane_path" rev-parse --abbrev-ref HEAD 2>/dev/null)

if [[ -n "$branch" ]]; then
  cache_dir="${TMPDIR:-/tmp}/tmux_pr_cache"
  mkdir -p "$cache_dir"

  repo_id=$(git -C "$pane_path" rev-parse --show-toplevel 2>/dev/null | tr '/' '_')
  cache_file="$cache_dir/${repo_id}_${branch}"

  if [[ -f "$cache_file" ]] && [[ $(( $(date +%s) - $(stat -f %m "$cache_file") )) -lt 300 ]]; then
    pr_info=$(cat "$cache_file")
  else
    pr_info=$(gh pr view "$branch" --repo "$(git -C "$pane_path" remote get-url origin 2>/dev/null)" --json number,state -q '"\(.number) \(.state)"' 2>/dev/null)
    echo "${pr_info:-}" > "$cache_file"
  fi

  pr_number="${pr_info%% *}"
  pr_state="${pr_info#* }"

  if [[ -n "$pr_number" ]]; then
    case "$pr_state" in
      MERGED) pr_prefix="(✓ #$pr_number) " ;;
      CLOSED) pr_prefix="(✗ #$pr_number) " ;;
      QUEUED) pr_prefix="(⧖ #$pr_number) " ;;
      *)      pr_prefix="(#$pr_number) " ;;
    esac
  fi
fi

if [[ "$session_name" == "$window_dir" ]]; then
  echo "${pr_prefix}${branch:-$window_dir}"
else
  echo "${pr_prefix}${window_dir}"
fi
