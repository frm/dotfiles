#!/bin/bash
#
# Determines the tmux window name based on context:
# - If session name matches the window's directory, show the git branch (or directory if not a repo)
# - Otherwise, show the window's directory name
# - Prepends PR status if the current branch has a PR:
#   "(✓ #123) " for checks passing, "(✗ #123) " for checks failing, "(⧖ #123) " for pending/queued
#   "(⇑ #123) " for merged, "(⊘ #123) " for closed
# Note: Manually set window names are preserved by tmux's automatic-rename behavior

pane_path="$1"
window_dir="${pane_path##*/}"
session_name=$(tmux display-message -p '#S')

# Look up PR number for the current branch, with file-based caching (5 min TTL)
# Disabled: redundant with context-panels which already show PR status.
# TODO: consider using gh-state IPC cache instead of direct gh calls.
pr_prefix=""
branch=$(git -C "$pane_path" rev-parse --abbrev-ref HEAD 2>/dev/null)

# if [[ -n "$branch" ]]; then
#   cache_dir="${TMPDIR:-/tmp}/tmux_pr_cache"
#   mkdir -p "$cache_dir"
