export LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8
if [ -n "$NVIM" ]; then
  export EDITOR='nvim-wait'
  export VISUAL='nvim-wait'
  export GIT_EDITOR='nvim-wait'
else
  export EDITOR='nvim'
fi

export PATH="$PATH:$HOME/.bin/:$HOME/.local/bin:$DOTFILES/bin:/usr/local/bin"

export CATPPUCCIN_VARIANT=mocha

export NVIM_MINUET_PROVIDER="openai"
export NVIM_MINUET_ENABLED="0"
