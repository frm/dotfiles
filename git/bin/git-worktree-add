#!/usr/bin/env sh
# creates a worktree for a branch, copying common build artifacts
# usage: git worktree-add [--reset] <branch>
#        git worktree-add [--reset] --pr <number>

set -e

#
# configs
#

_PROJECT_SECRETS=".env .envrc .pi"
_ELIXIR_ARTIFACTS="deps _build priv/plts .elixir_ls"
_JS_ARTIFACTS="node_modules assets"
_PROJECT_ARTIFACTS="$_PROJECT_SECRETS $_ELIXIR_ARTIFACTS $_JS_ARTIFACTS"

#
# aux functions
#

__echo_git() {
  echo "[git]: $1" >&2
}

# normalize branch path to max depth 1
# author/issue-id/description/other -> author/issue-id-description-other
__git_wt_normalize_branch_path() {
  case "$1" in
    */*/*)
      # 2+ slashes: keep first segment, join rest with dashes
      first="${1%%/*}"
      rest="${1#*/}"
      echo "$first/$(echo "$rest" | tr '/' '-')"
      ;;
    *)
      # 0-1 depth: keep as is
      echo "$1"
      ;;
  esac
}

# when we have a pr number instead, we use gh to extract the branch name
__git_wt_parse_opts_from_pr() {
  local pr_number="$1"
  local branch_name=""

  branch_name=$(gh pr view "$pr_number" --json headRefName -q '.headRefName') || {
    __echo_git "failed to fetch branch name for PR #$pr_number"
    return 1
  }

  __echo_git "PR #$pr_number -> branch: $branch_name"
  echo "$branch_name"
}

# parse the cli opts and args
_RESET=false

__git_wt_parse_opts() {
  local branch_name=""

  while [ $# -gt 0 ]; do
    case $1 in
      --reset|-r)
        _RESET=true
        shift
        ;;
      --pr)
        branch_name=$(__git_wt_parse_opts_from_pr "$2") || return 1
        shift 2
        ;;
      *)
        branch_name="$1"
        shift
        ;;
    esac
  done

  echo "$branch_name"
}

# determine what the worktree path should be
# depending on whether or not we're in a worktree already
__git_wt_infer_worktree_path() {
  local git_root="$1"
  local branch_name="$2"
  local repo_name=$(basename "$git_root")
  local worktrees_base=""

  case "$git_root" in
    */.worktrees/*)
      # if already inside a .worktrees directory, create sibling
      # extract repo name from path: .worktrees/<repo>/<branch>
      local after_worktrees="${git_root#*/.worktrees/}"
      local wt_repo_name="${after_worktrees%%/*}"
      worktrees_base="${git_root%/.worktrees/*}/.worktrees/$wt_repo_name"
      ;;
    *)
      worktrees_base="$(dirname "$git_root")/.worktrees/$repo_name"
      ;;
  esac

  local worktree_dir=$(__git_wt_normalize_branch_path "$branch_name")
  echo "$worktrees_base/$worktree_dir"
}

__git_wt_mkdir() {
  mkdir -p "$(dirname "$1")"
}

# attach the created worktree directory either to a new branch
# or an existing one
__git_wt_attach() {
  local worktree_path="$1"
  local branch_name="$2"
  local remote_ref="refs/remotes/origin/$branch_name"

  if git show-ref --verify --quiet "refs/heads/$branch_name"; then
    # local branch exists, use it
    git worktree add "$worktree_path" "$branch_name"
  elif git show-ref --verify --quiet "$remote_ref"; then
    # remote branch exists (already fetched), track it
    git worktree add --track "$worktree_path" -b "$branch_name" "origin/$branch_name"
  elif git fetch origin "$branch_name:$remote_ref" 2>/dev/null && git show-ref --verify --quiet "$remote_ref"; then
    # remote branch exists (just fetched), track it
    git worktree add --track "$worktree_path" -b "$branch_name" "origin/$branch_name"
  else
    # new branch, add without tracking upstream
    git worktree add "$worktree_path" -b "$branch_name"
  fi
}

# SHA256 hash of input, first 8 hex chars
__git_wt_hash_id() {
  local input="$1"
  local digest

  if command -v shasum >/dev/null 2>&1; then
    digest=$(printf '%s' "$input" | shasum -a 256 | awk '{print $1}')
  elif command -v sha256sum >/dev/null 2>&1; then
    digest=$(printf '%s' "$input" | sha256sum | awk '{print $1}')
  else
    __echo_git "missing shasum/sha256sum"
    return 1
  fi

  printf '%s' "$digest" | cut -c1-8
}

# upsert export KEY=VALUE in an env file
__git_wt_upsert_env() {
  local env_file="$1"
  local key="$2"
  local value="$3"
  local tmp_file="${env_file}.tmp.$$"

  if [ ! -f "$env_file" ]; then
    echo "export ${key}=${value}" > "$env_file"
    return
  fi

  awk -v key="$key" -v value="$value" '
  BEGIN { updated = 0 }
  $0 ~ "^export " key "=" {
    print "export " key "=" value
    updated = 1
    next
  }
  { print }
  END {
    if (!updated) {
      if (NR > 0) print ""
      print "export " key "=" value
    }
  }' "$env_file" > "$tmp_file"

  mv "$tmp_file" "$env_file"
}

# generate unique ports, derive unique names, and optionally isolate vars for a worktree
__git_wt_setup_env() {
  local worktree_path="$1"
  local env_file="${_MNDS_WORKTREE_ENV_FILE:-.envrc}"
  local full_env_path="$worktree_path/$env_file"

  [ -z "$_MNDS_WORKTREE_PORTS" ] && [ -z "$_MNDS_WORKTREE_RESET_VARS" ] && [ -z "$_MNDS_WORKTREE_DERIVED_VARS" ] && return 0

  local hash
  hash=$(__git_wt_hash_id "$worktree_path") || return 1

  if [ -n "$_MNDS_WORKTREE_PORTS" ]; then
    local num_ports=0
    for _entry in $_MNDS_WORKTREE_PORTS; do
      num_ports=$((num_ports + 1))
    done

    local seed
    seed=$(printf '%d' "0x$hash")
    local bucket=$((seed % 500))
    local i=0

    __echo_git "assigning worktree ports (bucket $bucket):"
    for entry in $_MNDS_WORKTREE_PORTS; do
      local var_name="${entry%%:*}"
      local port=$((20000 + bucket * num_ports + i))
      __git_wt_upsert_env "$full_env_path" "$var_name" "$port"
      __echo_git "  $var_name=$port"
      i=$((i + 1))
    done
  fi

  if [ "$_RESET" = true ] && [ -n "$_MNDS_WORKTREE_RESET_VARS" ]; then
    __echo_git "isolating reset vars:"
    for var_name in $_MNDS_WORKTREE_RESET_VARS; do
      local current_value=""
      if [ -f "$full_env_path" ]; then
        current_value=$(awk -v key="$var_name" '$0 ~ "^export " key "=" { sub("^export " key "=", ""); print }' "$full_env_path")
      fi
      if [ -n "$current_value" ]; then
        local new_value="${current_value}_wt_${hash}"
        __git_wt_upsert_env "$full_env_path" "$var_name" "$new_value"
        __echo_git "  $var_name=$new_value"
      fi
    done
  fi

  if [ -n "$_MNDS_WORKTREE_DERIVED_VARS" ]; then
    __echo_git "deriving unique vars:"
    for entry in $_MNDS_WORKTREE_DERIVED_VARS; do
      local var_name="${entry%%:*}"
      local base="${entry#*:}"
      local unique_value="${base}_${hash}"
      __git_wt_upsert_env "$full_env_path" "$var_name" "$unique_value"
      __echo_git "  $var_name=$unique_value"
    done
  fi
}

# pull latest changes if on main/master to ensure worktree starts fresh
__git_wt_pull_if_default_branch() {
  local current_branch
  current_branch=$(git rev-parse --abbrev-ref HEAD)

  if [ "$current_branch" = "main" ] || [ "$current_branch" = "master" ]; then
    __echo_git "on $current_branch, pulling latest changes..."
    git pull
  fi
}

__git_wt_notify() {
  local title="$1"
  local message="$2"
  osascript -e "display notification \"$message\" with title \"$title\""
}

__git_wt_cleanup_elixir_ls() {
  local worktree_path="$1"

  if [ -d "$worktree_path/.elixir_ls/build" ]; then
    __echo_git "[elixir] removing stale .elixir_ls/build cache..."
    rm -rf "$worktree_path/.elixir_ls/build"
  fi
}

__git_wt_cleanup_artifacts() {
  local worktree_path="$1"

  __git_wt_cleanup_elixir_ls "$worktree_path"
}

__git_wt_mix() {
  local worktree_path="$1"
  local env="$2"

  __echo_git "[mix:$env] fetching deps..."
  (cd "$worktree_path" && MIX_ENV="$env" mix deps.get)
  __echo_git "[mix:$env] compiling..."
  (cd "$worktree_path" && MIX_ENV="$env" mix compile)
  __echo_git "[mix:$env] creating database..."
  (cd "$worktree_path" && MIX_ENV="$env" mix ecto.create || true)
  __echo_git "[mix:$env] migrating..."
  (cd "$worktree_path" && MIX_ENV="$env" mix ecto.migrate)
}

__git_wt_yarn() {
  local worktree_path="$1"

  __echo_git "[yarn] installing deps..."
  (cd "$worktree_path" && yarn install)
}

# install deps and compile the project
__git_wt_compile() {
  local worktree_path="$1"

  if [ -f "$worktree_path/mix.exs" ]; then
    __git_wt_mix "$worktree_path" dev
    __git_wt_mix "$worktree_path" test
  fi

  if [ -f "$worktree_path/package.json" ]; then
    __git_wt_yarn "$worktree_path"
  fi
}

# copy a single artifact with a spinner
__git_wt_cp_with_spinner() {
  local src="$1"
  local dest="$2"
  local name="$3"

  cp -r "$src" "$dest" 2>/dev/null &
  local cp_pid=$!

  local i=0
  while kill -0 "$cp_pid" 2>/dev/null; do
    case $((i % 10)) in
      0) c='⠋' ;; 1) c='⠙' ;; 2) c='⠹' ;; 3) c='⠸' ;; 4) c='⠼' ;;
      5) c='⠴' ;; 6) c='⠦' ;; 7) c='⠧' ;; 8) c='⠇' ;; 9) c='⠏' ;;
    esac
    printf '\r       %s copying %s...' "$c" "$name" >&2
    i=$((i + 1))
    sleep 0.1
  done

  wait "$cp_pid" 2>/dev/null || true
  printf '\r       \033[K' >&2
}

# copy over project artifacts so we don't have to recompile, reset secrets, etc
# this includes project-specific artifacts defined via _MNDS_WORKTREE_PROJECT_ARTIFACTS
__git_wt_cp_artifacts() {
  local git_root="$1"
  local worktree_path="$2"
  local all_artifacts="$_PROJECT_ARTIFACTS $_MNDS_WORKTREE_PROJECT_ARTIFACTS"

  for pattern in $all_artifacts; do
    for item in $git_root/$pattern; do
      [ -e "$item" ] || continue
      local rel_path="${item#$git_root/}"
      local dest_dir="$worktree_path/$(dirname "$rel_path")"
      mkdir -p "$dest_dir"
      __git_wt_cp_with_spinner "$item" "$dest_dir/" "$(basename "$item")"
    done
  done

  printf '       ✓ all artifacts copied\n' >&2
}

# compile + env setup + post-setup hook in background, notify on completion
__git_wt_compile_async() {
  local worktree_path="$1"
  local git_root="$2"
  local branch_name="$3"
  local log_file="$worktree_path/.log/git-wt-compile.log"

  mkdir -p "$worktree_path/.log"

  (
    set +e
    _wt_ok=true

    __git_wt_setup_env "$worktree_path" || _wt_ok=false

    if [ "$_wt_ok" = true ]; then
      __git_wt_compile "$worktree_path" || _wt_ok=false
    fi

    if [ "$_wt_ok" = true ] && [ -n "$_MNDS_WORKTREE_POST_SETUP" ]; then
      __echo_git "running post-setup hook..."
      if [ "$_RESET" = true ]; then
        (cd "$worktree_path" && $_MNDS_WORKTREE_POST_SETUP "$worktree_path" "$git_root" --reset) || _wt_ok=false
      else
        (cd "$worktree_path" && $_MNDS_WORKTREE_POST_SETUP "$worktree_path" "$git_root") || _wt_ok=false
      fi
    fi

    if [ "$_wt_ok" = true ]; then
      __git_wt_notify "Worktree ready" "Compile finished for $branch_name"
    else
      __git_wt_notify "Worktree compile failed" "Check $log_file"
    fi
  ) >> "$log_file" 2>&1 &

  __echo_git "compiling in background (log: $log_file)"
}

#
# main script
#

branch_name=$(__git_wt_parse_opts "$@") || exit 1

if [ -z "$branch_name" ]; then
  __echo_git "branch name required"
  echo "usage: git worktree-add [--reset] <branch>" >&2
  echo "       git worktree-add [--reset] --pr <number>" >&2
  exit 1
fi

git_root=$(git rev-parse --show-toplevel)
worktree_path=$(__git_wt_infer_worktree_path "$git_root" "$branch_name")

if [ -d "$worktree_path" ]; then
  __echo_git "worktree already exists at $worktree_path"
  echo "$worktree_path"
  exit 0
fi

__git_wt_pull_if_default_branch

__echo_git "creating worktree at $worktree_path"
__git_wt_mkdir "$worktree_path"
__git_wt_attach "$worktree_path" "$branch_name"
__echo_git "copying artifacts..."
__git_wt_cp_artifacts "$git_root" "$worktree_path"
__git_wt_cleanup_artifacts "$worktree_path"

__git_wt_compile_async "$worktree_path" "$git_root" "$branch_name"

__echo_git "worktree created at $worktree_path"
echo "$worktree_path"
