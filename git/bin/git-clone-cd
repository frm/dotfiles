#!/usr/bin/env sh
# clone a repo and echo the directory path for cd

set -e

if [ $# -eq 0 ]; then
  echo "[git]: repository required" >&2
  exit 1
fi

if command -v gh >/dev/null 2>&1; then
  gh repo clone "$@"
else
  git clone "$@"
fi

# extract directory name: use custom dir if provided, otherwise derive from repo
if [ $# -ge 2 ] && [ "$2" != "--" ] && case "$2" in -*) false;; *) true;; esac; then
  dir="$2"
else
  dir=$(echo "$1" | awk -F / '{ print $NF }' | sed 's/.git//g')
fi

echo "$dir"
