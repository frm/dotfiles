#!/usr/bin/env sh
# deletes a branch (and its worktree if one exists)
# usage: git del [-f] <branch>
# -f: also delete the remote branch

set -e

#
# aux functions
#

__echo_git() {
  echo "[git]: $1" >&2
}

__git_del_usage() {
  __echo_git "branch name required"
  echo "usage: git del [-f] <branch>" >&2
}

__git_del_is_inside_path() {
  case "$PWD" in
    "$1"|"$1"/*) return 0 ;;
    *) return 1 ;;
  esac
}

__git_del_output_main_worktree() {
  if [ "$__git_del_needs_cd" = true ]; then
    git worktree list --porcelain | grep "^worktree " | head -1 | cut -d' ' -f2
  fi
}

__git_del_teardown_elixir() {
  local worktree_path="$1"
  local env_file="${_MNDS_WORKTREE_ENV_FILE:-.envrc}"
  local full_env_path="$worktree_path/$env_file"

  [ ! -f "$worktree_path/mix.exs" ] && return 0
  [ -z "$_MNDS_WORKTREE_ISOLATED_VARS" ] && return 0
  [ ! -f "$full_env_path" ] && return 0

  # check if any DB var has a _wt_ isolated value
  local has_isolated_db=false
  for var_name in $_MNDS_WORKTREE_ISOLATED_VARS; do
    local value
    value=$(awk -v key="$var_name" '$0 ~ "^export " key "=" { sub("^export " key "=", ""); print }' "$full_env_path")
    case "$value" in *_wt_*) has_isolated_db=true; break ;; esac
  done

  [ "$has_isolated_db" = false ] && return 0

  __echo_git "[elixir] dropping isolated databases..."
  for env in dev test; do
    (cd "$worktree_path" && . "$full_env_path" && MIX_ENV="$env" mix ecto.drop) 2>/dev/null || true
  done
}

__git_del_teardown_hook() {
  local worktree_path="$1"

  [ -z "$_MNDS_WORKTREE_PRE_TEARDOWN" ] && return 0

  local git_root
  git_root=$(cd "$worktree_path" && git rev-parse --show-toplevel 2>/dev/null) || true

  __echo_git "running teardown hook..."
  (cd "$worktree_path" && $_MNDS_WORKTREE_PRE_TEARDOWN "$worktree_path" "$git_root") || true
}

__git_del_teardown() {
  local worktree_path="$1"

  __git_del_teardown_elixir "$worktree_path"
  __git_del_teardown_hook "$worktree_path"
}

__git_del_remove_worktree() {
  local branch_name="$1"
  local worktree_path=""

  worktree_path=$(git worktree list --porcelain \
    | grep -B2 "^branch refs/heads/$branch_name$" \
    | grep "^worktree " \
    | cut -d' ' -f2) || true

  if [ -n "$worktree_path" ]; then
    if __git_del_is_inside_path "$worktree_path"; then
      __git_del_needs_cd=true
    fi

    __git_del_teardown "$worktree_path"
    __echo_git "removing worktree at $worktree_path"
    git worktree remove "$worktree_path" --force
  fi
}

__git_del_delete_local_branch() {
  local branch_name="$1"

  if git rev-parse --verify "$branch_name" >/dev/null 2>&1; then
    __echo_git "deleting local branch '$branch_name'"
    git branch -D "$branch_name"
  else
    __echo_git "local branch '$branch_name' does not exist, skipping"
  fi
}

__git_del_delete_remote_branch() {
  local branch_name="$1"

  if git ls-remote --exit-code --heads origin "$branch_name" >/dev/null 2>&1; then
    __echo_git "deleting remote branch '$branch_name'"
    git push origin --delete "$branch_name"
  else
    __echo_git "remote branch '$branch_name' does not exist, skipping"
  fi
}

#
# main script
#

delete_remote=false
__git_del_needs_cd=false

while getopts "f" opt; do
  case $opt in
    f) delete_remote=true ;;
    *) ;;
  esac
done
shift $((OPTIND - 1))

if [ -z "$1" ]; then
  __git_del_usage
  exit 1
fi

branch_name="$1"

__git_del_remove_worktree "$branch_name"
__git_del_delete_local_branch "$branch_name"

if [ "$delete_remote" = true ]; then
  __git_del_delete_remote_branch "$branch_name"
fi

__echo_git "done"

__git_del_output_main_worktree
