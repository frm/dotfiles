#! /usr/bin/env sh

# The following error might happen during mise install
# because postgres needs OpenSSL headers/libs explicitly:
# configure: error: library 'crypto' is required for OpenSSL
#
# These flags solve it.
export POSTGRES_EXTRA_CONFIGURE_OPTIONS="
  --with-lz4
  --with-uuid=e2fs
  --with-libraries=/usr/local/lib:$(brew --prefix openssl@3)/lib
  --with-includes=/usr/local/include:$(brew --prefix openssl@3)/include"

pg_server() {
  pg_version=$(pg_ctl --version | cut -d ' ' -f3)
  pg_dir="$HOME/.mise/installs/postgres/$pg_version/data"

  pg_ctl -D $pg_dir -l "$pg_dir/server.log" "$@"
}

alias pg.server="pg_server"
